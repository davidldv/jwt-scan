{
  "name": "jwt-scan",
  "version": "0.1.1",
  "description": "CLI scanner for JWT misconfigurations: alg=none, key confusion, weak secrets, kid injection, claim validation.",
  "keywords": [
    "jwt",
    "security",
    "scanner",
    "appsec",
    "cli",
    "audit"
  ],
  "license": "MIT",
  "author": "David Londoño",
  "homepage": "https://github.com/davidldv/jwt-scan#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidldv/jwt-scan.git"
  },
  "bugs": {
    "url": "https://github.com/davidldv/jwt-scan/issues"
  },
  "type": "module",
  "bin": {
    "jwt-scan": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "wordlists",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "undici": "^6.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
